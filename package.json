{
  "name": "native-ui",
  "private": true,
  "scripts": {
    "build": "pnpm --filter @native-ui/ui build",
    "dev:example": "pnpm --filter @native-ui/example start",
    "dev:docs": "pnpm --filter @native-ui/docs dev",
    "build:docs": "pnpm --filter @native-ui/docs build",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean"
  },
  "devDependencies": {
    "typescript": "~5.3.3"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "packageManager": "pnpm@9.15.4"
}
